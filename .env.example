# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...          # Service role key (bukan anon key)
SUPABASE_JWT_SECRET=your-jwt-secret  # Settings > API > JWT Secret

# Database (Supabase connection pooler — Transaction mode, port 6543)
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Google Gemini
GEMINI_API_KEY=AIza...

# App
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
